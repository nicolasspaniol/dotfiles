[user]
	email = nicolasmspaniol@gmail.com
	name = nmspaniol
[rerere]
	enabled = true
[init]
	defaultBranch = main
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[diff]
	algorithm = histogram
[branch]
	sort = committerdate
[merge]
	conflictstyle = diff3
